(715,7,'构建原则',NULL,'确定标准','数据集自身采用的标签与特征应达到行业共识，确保数据集的规范性和可靠性',0),
(716,7,'构建原则',NULL,'迭代改进','构建最小必要数据集完整闭环，能快速形成数量级的迭代提升和改进，形成更大规模数据集',0),
(717,7,'构建原则',NULL,'评估性强','针对命名实体识别、关系抽取、事件抽取、文本分类等不同任务，在评价指标上能取得较好的效果，可持续评估并不断完善',0),
(718,7,'构建一般步骤',NULL,'步骤 1：明确建模需求','明确数据集预期支撑的建模任务',0),
(719,7,'构建一般步骤',NULL,'步骤 2：数据标注加工','按照预定目标及要求进行人工标注',0),
(720,7,'构建一般步骤',NULL,'步骤 3：数据审核评估','对数据集的规范性、完整性等进行审核，并对相应训练后的模型性能进行评估',0),
(721,7,'构建一般步骤',NULL,'步骤 4：数据修订完善','根据评估结果对数据集不断迭代加工与修改完善',0),
(722,7,'构建主要方法 - 明确建模需求',NULL,'数据预处理','包括文本分段、去除停用词、词干提取、词形还原、词袋模型、词嵌入等',0),
(723,7,'构建主要方法 - 明确建模需求',NULL,'明确建模类型','明确支撑哪类模型的构建，如命名实体识别、关系抽取、事件抽取和文本分类等',0),
(724,7,'构建主要方法 - 明确建模需求',NULL,'明确标签类别与数量','根据任务明确支撑模型构建所需要的标签类别与数量（如命名实体识别中的实体类别及数量、关系抽取中的关系类别及数量、文本分类中的类别标签及数量等）',0),
(725,7,'构建主要方法 - 数据标注加工',NULL,'手动标注','由专业人员进行人工标注',0),
(726,7,'构建主要方法 - 数据标注加工',NULL,'半自动标注','利用规则或模型进行初步标注，然后由专业人员进行修正',0),
(727,7,'构建主要方法 - 数据标注加工',NULL,'自动标注','使用训练好的模型进行标注',0),
(728,7,'构建主要方法 - 数据审核评估',NULL,'性能指标','包括标注错误率，模型的准确率、召回率、F1 值、ROC 曲线、AUC 值等',0),
(729,7,'构建主要方法 - 数据审核评估',NULL,'人工审核','对比分析模型在哪些类型的数据上表现不好，同时进行人工审核，以便于优化',0),
(730,7,'构建主要方法 - 数据修订完善',NULL,'标注错误修正','根据审核结果与模型评估结果对特定样本中存在的错误进行标注修正',0),
(731,7,'构建主要方法 - 数据修订完善',NULL,'样本数量补充','根据经典模型的训练与测试评估，适度增加标注样本的数量，以提升模型的性能与可用性',0),
(732,7,'附录 A - 文本数据常见标注加工模式',NULL,'A.1 需求方标注 - 适用场景','数据保密性强，需要及时沟通协调的任务',0),
(733,7,'附录 A - 文本数据常见标注加工模式',NULL,'A.1 需求方标注 - 要求','1. 有专业的人员或团队进行标注，对任务领域有深入的理解；2. 有能够支持标注任务的标注工具或平台，能够存储、管理和查看标注数据；3. 有明确的标注规则，标注人员按照相同的规则进行标注；4. 有质量控制机制，定期进行标注质量的检查和评估；5. 有数据保护和备份的机制，确保数据的安全性',0),
(734,7,'附录 A - 文本数据常见标注加工模式',NULL,'A.2 第三方标注 - 适用场景','自身标注能力有限，且对业务流程要求不高的任务',0),
(735,7,'附录 A - 文本数据常见标注加工模式',NULL,'A.2 第三方标注 - 要求','1. 第三方有专业的标注团队和成熟的标注工具；2. 第三方有数据保密和安全的保障措施；3. 第三方有高效的标注流程和管理机制；4. 有明确的委托协议，包括交付期限，数据的使用、保护、所有权等问题；5. 需求方定期进行质量审核，确保标注质量达标',0),
(736,7,'附录 A - 文本数据常见标注加工模式',NULL,'A.3 众包标注 - 适用场景','时间紧、标注数据量大、数据保密和隐私性要求不高的任务',0),
(737,7,'附录 A - 文本数据常见标注加工模式',NULL,'A.3 众包标注 - 要求','1. 有大量的众包标注者，并开展培训以理解标注任务；2. 有支持大规模并行标注的平台和工具；3. 有明确的标注规则，以及对标注质量的评估机制；4. 有激励机制，鼓励标注者提供高质量的标注',0),
(738,7,'附录 B - 面向信息抽取的文本数据常见标注方法',NULL,'B.1 命名实体识别数据集标注方法 - 标记法类型','BIO 标记法、BIOES 标记法',0),
(739,7,'附录 B - 面向信息抽取的文本数据常见标注方法',NULL,'B.1 命名实体识别数据集标注方法 - 标签定义','B-Entity：Begin，表示实体中的第一个字符；I-Entity：Intermediate，表示实体中间的字符；O：Other，表示非识别实体；E-Entity：End，表示实体中的最后一个字符；S-Entity：Single，表示一个单独字符构成的实体',0),
(740,7,'附录 B - 面向信息抽取的文本数据常见标注方法',NULL,'B.1 命名实体识别数据集标注方法 - 示例','文本 “主诉：呼吸困难 2 天。”，BIOES 标注结果：主（O）、诉（O）、呼（B - 阳性症状）、吸（I - 阳性症状）、困（I - 阳性症状）、难（E - 阳性症状）、2（B - 持续时间）、天（E - 持续时间）、。（O）',0),
(741,7,'附录 B - 面向信息抽取的文本数据常见标注方法',NULL,'B.2 关系抽取数据集标注方法 - 标注流程','1. 结合命名实体识别数据集中抽取的主要实体，设计实体间关系的定义；2. 找出句子中包含的实体类别；3. 确定实体间存在的关系；4. 将所有实体两两配对，得到所有实体的组合对；5. 添加原始的文本数据；6. 按照 “关系名 实体 1 实体 2 原始数据” 的格式生成标注后的关系数据集（各部分之间使用空格符号分隔）',0),
(742,7,'附录 B - 面向信息抽取的文本数据常见标注方法',NULL,'B.2 关系抽取数据集标注方法 - 示例','文本 “桂枝汤主治头痛发热，汗出恶风”，标注结果：1. 方症关系 桂枝汤 头痛 桂枝汤主治头痛发热，汗出恶风；2. 方症关系 桂枝汤 发热 桂枝汤主治头痛发热，汗出恶风；3. 方症关系 桂枝汤 汗出 桂枝汤主治头痛发热，汗出恶风；4. 方症关系 桂枝汤 恶风 桂枝汤主治头痛发热，汗出恶风',0),
