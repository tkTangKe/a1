(1469,10,'数据格式规范 - 闻诊（声音）采集信息',NULL,'数据命名格式','ID + 姓名 + 声诊 + 日期 + 示例名称.wav/mp3/wma',0),
(1470,10,'数据格式规范 - 闻诊（声音）采集信息',NULL,'原则','仅需录入受试者的声音，否则需要注明受试者的音频时间序列；尽量避免周围环境噪声影响',0),
(1471,10,'数据格式规范 - 问诊采集信息',NULL,'数据存储格式','csv 文件 /excel 文件',0),
(1472,10,'数据格式规范 - 问诊采集信息',NULL,'格式要求 1','必须完整添加受试者姓名、唯一标识 ID 号、日期等基本信息',0),
(1473,10,'数据格式规范 - 问诊采集信息',NULL,'格式要求 2','每一列都需表明数据类别（即表头信息）',0),
(1474,10,'数据格式规范 - 问诊采集信息',NULL,'格式要求 3','信息导出的统计文件中每位受试者对应 1 行数据，所有受试者数据合并为 1 个统计文件',0),
(1475,10,'数据格式规范 - 问诊采集信息',NULL,'原则','数值标签对照表头样例收集的数据必须遵循命名规范原则，保证脱离原始问卷调查表也能清楚统计文件内容含义',0),
(1476,10,'数据格式规范 - 脉诊采集信息',NULL,'数据存储格式','UTF-8 编码方式，存储为 txt 文本文件',0),
(1477,10,'数据格式规范 - 脉诊采集信息',NULL,'脉诊频率','采样频率保持一致（200-1000Hz），原始数据保留小数点后六位',0),
(1478,10,'数据格式规范 - 脉诊采集信息',NULL,'脉诊采集部位','左手寸、左手关、左手尺、右手寸、右手关、右手尺',0),
(1479,10,'数据格式规范 - 脉诊采集信息',NULL,'数据命名格式','ID + 姓名 + 脉诊 + 日期.txt',0),
(1480,10,'数据格式规范 - 脉诊采集信息',NULL,'数据规范','脉诊数据与临床量表要保持对应（信息分类准确、姓名无错别字），每个受试者的信息整合为 1 个包含双手寸、关、尺脉诊信息的文本文件',0),
(1481,10,'附录 A - 望诊信息采集注意事项',NULL,'对受试者要求 - 心身状态','1. 宜在心情平静、呼吸均匀、全身放松、主动配合的状态下接受诊查；2. 若受试者不能配合（如神志昏迷、神乱、语言障碍、听力障碍、不愿意配合等），可灵活掌握，必要时中止采集',0),
(1482,10,'附录 A - 望诊信息采集注意事项',NULL,'对受试者要求 - 体位姿势','1. 一般采取坐位；2. 可根据诊察需要，在工作人员指导下改变体位或做出相应动作；3. 需充分暴露受检部位',0),
(1483,10,'附录 A - 望诊信息采集注意事项',NULL,'对受试者要求 - 着装打扮','需以素颜状态进行采集，避免化妆导致的人为因素干扰',0),
(1484,10,'附录 A - 望诊信息采集注意事项',NULL,'体内外环境要求','1. 建议气温在 15-25 摄氏度，自然舒适的环境；2. 注意饮酒、饮食、药物、情绪、运动、日晒等体内外因素对眼睛、面色、舌苔、舌色等的影响（如食用火龙果、橘子，愤怒情绪等），避免在这些因素影响下采集',0),
(1485,10,'附录 A - 望诊信息采集注意事项',NULL,'工作人员要求 - 语言表达','1. 尽量用简单、通俗的语言；2. 指令准确、语速慢；3. 注意口语和术语的转换，避免使用医学术语；4. 有目的、顺序地与受试者交流',0),
(1486,10,'附录 A - 望诊信息采集注意事项',NULL,'工作人员要求 - 设备操作','1. 正确使用望诊信息设备；2. 按流程规范操作；3. 拍摄部位准确、图片清晰',0),
(1487,10,'附录 B - 闻诊（声音）信息采集注意事项',NULL,'对受试者要求 - 心身状态','1. 宜在心情平静、呼吸均匀、全身放松、主动配合的状态下接受诊查；2. 若受试者不能配合（如神志昏迷、神乱、语言障碍、听力障碍、不愿意配合等），可灵活掌握，必要时中止采集',0),
(1488,10,'附录 B - 闻诊（声音）信息采集注意事项',NULL,'对受试者要求 - 体位姿势','1. 一般采取坐位或仰卧位；2. 可根据诊察需要，在工作人员指导下完成相关语音录制',0),
(1489,10,'附录 B - 闻诊（声音）信息采集注意事项',NULL,'体内外环境要求','1. 建议气温在 15-25 摄氏度，自然舒适的环境；2. 注意饮酒、饮食、药物、情绪、运动等体内外因素（如醉酒状态、情绪紧张、饮用功能性饮料等）对受试者音量、语速等的影响',0),
(1490,10,'附录 B - 闻诊（声音）信息采集注意事项',NULL,'工作人员要求 - 语言表达','1. 尽量用简单、通俗的语言；2. 指令准确、语速慢；3. 避免使用医学术语；4. 有目的、顺序地与受试者交流',0),
(1491,10,'附录 B - 闻诊（声音）信息采集注意事项',NULL,'工作人员要求 - 设备操作','1. 正确使用闻诊信息设备；2. 按流程规范操作；3. 尽量避免周围环境噪声影响，保证录制语音清晰',0),
(1492,10,'附录 C - 问诊信息采集注意事项',NULL,'对受试者要求','1. 一般采取坐位或仰卧位；2. 需在工作人员指导下主动配合地提供真实、可靠的与疾病相关信息',0),
(1493,10,'附录 C - 问诊信息采集注意事项',NULL,'体内外环境要求','建议气温在 15-25 摄氏度，自然舒适的环境下进行',0),
(1494,10,'附录 C - 问诊信息采集注意事项',NULL,'工作人员要求 - 心身状态','问诊者要有高度的同情心、责任感，态度和蔼、庄重，体贴、关心受试者，耐心细致地与受试者交谈，消除受试者的紧张与不安，让受试者在心情平静、呼吸均匀、全身放松、主动配合的状态下接受询问',0),
(1495,10,'附录 C - 问诊信息采集注意事项',NULL,'工作人员要求 - 语言表达','1. 尽量用简单、通俗的语言；2. 指令准确、语速慢；3. 避免使用医学术语；4. 有目的、顺序地与受试者交流；5. 避免暗示性提问，对涉及隐私的问题（如精神病或性病史）可间接询问相关症状；6. 专心听受试者叙述，尽量不打断，保证问诊连贯性与真实性；7. 领会俗语、方言，记录时使用医学术语',0),
(1496,10,'附录 C - 问诊信息采集注意事项',NULL,'工作人员要求 - 保护隐私','问及受试者个人信息及隐私时，需严格保密',0),
(1497,10,'附录 C - 问诊信息采集注意事项',NULL,'工作人员要求 - 区分对象','1. 根据受试者年龄、性别及疾病类别进行针对性询问；2. 受试者本人叙述有困难时（如老年人、方言导致的语言障碍者、精神病患者等），可由家属或知情者代述',0),
(1498,10,'附录 D - 脉诊信息采集注意事项',NULL,'对受试者要求 - 心身状态','1. 宜在心情平静、呼吸均匀、全身放松、主动配合的状态下接受诊查；2. 若受试者不能配合（如上肢关节僵硬、神志昏迷、不愿意配合等），可灵活掌握，必要时中止采集；3. 脉诊采集时不进行问诊，避开咳嗽、喷嚏等时刻',0),
(1499,10,'附录 D - 脉诊信息采集注意事项',NULL,'对受试者要求 - 体位姿势','一般采取坐位，在工作人员指导下完成相关信息采集',0),
(1500,10,'附录 D - 脉诊信息采集注意事项',NULL,'对受试者要求 - 解除压迫','需解除压迫被诊手臂的物件（如手表、手镯、包、扣紧的袖口等）',0),
(1501,10,'附录 D - 脉诊信息采集注意事项',NULL,'体内外环境要求','注意体内、外因素对受试者脉诊信息的影响（原文未明确具体因素，按原文表述记录）',0),
(1502,10,'附录 D - 脉诊信息采集注意事项',NULL,'工作人员要求 - 语言表达','1. 尽量用简单、通俗的语言；2. 指令准确、语速慢；3. 避免使用医学术语；4. 有目的、顺序地与受试者交流',0),
(1503,10,'附录 D - 脉诊信息采集注意事项',NULL,'工作人员要求 - 设备操作','原文未明确详细要求，按原文表述记录（需正确使用脉诊采集设备，按流程规范操作）',0),
