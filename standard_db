(1458,10,'数据格式规范 - 目诊采集信息',NULL,'数据命名格式','ID - 姓名 + 目诊 + 日期 + 采集部位.jpg',0),
(1459,10,'数据格式规范 - 目诊采集信息',NULL,'原则','拍摄位置充分暴露，拍摄图片清晰',0),
(1460,10,'数据格式规范 - 舌面诊采集信息',NULL,'数据存储格式','Jpg 图片',0),
