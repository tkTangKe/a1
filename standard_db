/*Table structure for table `term` */

DROP TABLE IF EXISTS `term`;

CREATE TABLE `term` (
  `id` int NOT NULL AUTO_INCREMENT,
  `name` varchar(100) NOT NULL,
  `definition` text,
  `category` varchar(50) DEFAULT NULL COMMENT '分类：基础设施/数据资源/应用系统/支撑体系',
  `source_standard` varchar(100) DEFAULT NULL COMMENT '来源标准编号',
  `standard_doc_id` int DEFAULT NULL,
  PRIMARY KEY (`id`)
) ENGINE=InnoDB AUTO_INCREMENT=607 DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_0900_ai_ci;

/*Data for the table `term` */

insert  into `term`(`id`,`name`,`definition`,`category`,`source_standard`,`standard_doc_id`) values 
(1,'中医药信息','指中医药领域产生或涉及的各类信息的总称（注：改写 SL/Z 376-2007，定义 3.0.1）','基础','T/CIATCM 001-2019',1),
(2,'中医药信息化','指应用信息技术，开发和利用中医药信息资源，促进信息交流与知识共享，提升中医药各领域的效率和效益的过程（注：改写 SL/Z 376-2007，定义 3.0.2）','基础','T/CIATCM 001-2019',1),
(3,'中医药信息管理','指以信息技术为手段，对中医药信息资源进行计划、组织、领导和控制的活动（注：改写 HY/T 131-2010，定义 5.1）','基础','T/CIATCM 001-2019',1),
(4,'中医药信息资源开发利用','指利用信息技术对中医药信息资源进行采集、处理、存储、交换、共享、服务和应用的活动（注：改写 JGJ/T 313-2013，定义 2.0.23）','基础','T/CIATCM 001-2019',1),
(5,'中医药信息数字化','指以数字形式表达中医药特性和中医药信息，或以计算机特定识别符号，将中医药信息以数字形式表达或表示出来（注：改写 HY/T 131-2010，定义 4.12）','基础','T/CIATCM 001-2019',1),
(6,'中医药信息平台','指基于信息基础设施，按照信息共享要求和相关技术标准建立的、服务于中医药行业各种信息系统和信息应用的技术系统，可包括统一的公共信息平台、面向公众的信息服务平台以及面向行业应用的专业信息平台等（注：改写 JGJ/T 313-2013，定义 2.0.12）','基础','T/CIATCM 001-2019',1),
(7,'中医药数据中心','指一种机构，它包括人员、硬件和软件，将它们组织起来以提供中医药信息处理服务（注：改写 GB/T 5271.1-2000，定义 01.01.19）','基础','T/CIATCM 001-2019',1),
(8,'中医药电子政务','指中医药政务部门应用信息技术，结合技术的实施过程来强化政府与政府、政府与企事业单位以及政府与公众之间的信息沟通与互动，提高并改进政府管理与服务水平的工作模式（注：改写 GB/T 30850.1-2014，定义 3.1）','基础','T/CIATCM 001-2019',1),
(9,'中医药综合统计','指对中医药事业改革与发展情况进行统计调查和分析','基础','T/CIATCM 001-2019',1),
(10,'中医知识库','指一种数据库，包含有关中医药领域人类经验和专家的推理规则和信息（注：改写 GB/T 5271.1-2000，定义 01.06.18）','基础','T/CIATCM 001-2019',1),
(11,'信息','关于客体（如事实、事件、事物、过程或思想，包括概念）的知识，在一定的场合中具有特定的意义（[GB/T 5271.1-2000，定义 01.01.01]）','基础','T/CIATCM 001-2019',1),
(12,'数据','信息的可再解释的形式化表示，以适用于通信、解释或处理（[GB/T 5271.1-2000，定义 01.01.02]）','基础','T/CIATCM 001-2019',1),
(13,'数据管理','在数据处理系统中，提供对数据的访问，执行或监视数据的存储，以及控制输入输出操作等功能（[GB/T 5271.1-2000，定义 01.08.02]）','基础','T/CIATCM 001-2019',1),
(14,'数据集','具有一定主题，可以标识并可以被计算机处理的数据集合（[WS/T 306-2009，定义 3.1]）','基础','T/CIATCM 001-2019',1),
(15,'基本数据集','在特定主题下，为了满足业务信息系统规范化建设和领域内部以及领域间数据交换和共享需求，设计归纳的最小数据元素的集合（[WS/T 370-2012，定义 3.1]）','基础','T/CIATCM 001-2019',1),
(16,'数据集编码','在分类的基础上，给数据集赋予的有一定规律性、计算机容易识别与处理的符号（[WS/T 306-2009，定义 3.2]）','基础','T/CIATCM 001-2019',1),
(17,'数据集标引','指分析数据集的内容属性及相关外表属性，并用特定语言表达分析出的属性或特征，从而赋予数据集检索标识的过程（[WS/T 306-2009，定义 3.3]）','基础','T/CIATCM 001-2019',1),
(18,'数据交换','指在多个数据终端之间，为任意两个终端设备建立数据通信临时互连通路的过程','基础','T/CIATCM 001-2019',1),
(19,'数据提取、转换和加载','指将分布的、异构数据源中的数据（如关系数据、平面数据文件等）抽取到临时中间层后进行清洗、转换、集成，最后加载到数据仓库','基础','T/CIATCM 001-2019',1),
(20,'数据维护','指对数据和数据库进行的日常维护与监控、备份与恢复、应急处理和监督管理等工作','基础','T/CIATCM 001-2019',1),
(21,'数据元','用一组属性规定其定义、标识、表示和允许值的数据单元（[GB/T 18391.1-2009，定义 3.3.8]）','基础','T/CIATCM 001-2019',1),
(22,'文件交换格式','（原文未明确定义，按原文表述记录）','基础','T/CIATCM 001-2019',1),
(23,'信息编码','指事物或概念（编码对象）赋予具有一定规律、易于计算机和人识别处理的符号，形成代码元素集合（[GB/T 7027-2002，定义 4.2]）','基础','T/CIATCM 001-2019',1),
(24,'信息分类','把具有某种共同属性或特征的信息归并在一起，把具有不同属性或特征的信息区别开来的过程（[GB/T 10113-2003，定义 2.1.3]）','基础','T/CIATCM 001-2019',1),
(25,'信息共享','指依据政策法规和标准规范，在一定范围和层次上实现信息流通与共用的机制','基础','T/CIATCM 001-2019',1),
(26,'中医药信息基础设施','指为中医药信息化提供基本信息采集、传输、处理、存储和开发利用的各种软件和硬件的总称（注：改写 HY/T 131-2010，定义 2.12）','基础设施','T/CIATCM 001-2019',1),
(27,'内联网','指专用于一个组织内部的计算机网络，它使用一些或所有的互联网协议和技术（注：改写 GB/T 2900.96-2015，定义 732-07-22）','基础设施','T/CIATCM 001-2019',1),
(28,'外联网','指把一个内联网扩展成可以有选择地访问外部组织以及可以有选择地允许外部组织访问的那部分网络，可被选择的外部组织可以是该单位的客户或提供商，但不是一般公众（注：改写 GB/T 2900.96-2015，定义 732-07-23）','基础设施','T/CIATCM 001-2019',1),
(29,'单点登录','指在多个应用系统中，用户只需要登录一次就可以访问所有相互信任的应用系统，它包括可以将这次主要的登录映射到其他应用中用于同一个用户的登录的机制','基础设施','T/CIATCM 001-2019',1),
(30,'云计算','一种通过网络将可伸缩、弹性的共享物理和虚拟资源池以按需自服务的方式供应和管理的模式（[GB/T 32400-2015，定义 3.2.5]）','基础设施','T/CIATCM 001-2019',1),
(31,'云服务','通过云计算已定义的接口提供的一种或多种能力（[GB/T 32400-2015，定义 3.2.9]）','基础设施','T/CIATCM 001-2019',1),
(32,'主机房','主要用于电子信息处理、存储、交换和传输设备的安装和运行的建筑空间，包括服务器机房、网络机房、存储机房等功能区域（[GB/T 50174-2008，定义 2.0.3]）','基础设施','T/CIATCM 001-2019',1),
(33,'中医医院综合管理数据','指中医医院综合（运营）管理数据的总称，包括人力、物力、财力和业务等资源管理数据，及医院文化与环境建设、服务与安全等管理数据','数据资源','T/CIATCM 001-2019',1),
(34,'中医药综合统计信息基本数据集','指中医药行业综合统计最小数据元素的集合，用于中医药综合统计信息系统开发、数据交换与共享利用','数据资源','T/CIATCM 001-2019',1),
(35,'中医药人力资源数据','指中医药行业员工的招募与选拔、培训与开发、绩效管理、薪酬管理、员工流动管理、员工关系管理、员工安全与健康管理等人力资源管理数据的总称','数据资源','T/CIATCM 001-2019',1),
(36,'中医药财务管理数据','指中医药企事业单位内部的预算管理、收入管理、支出管理、资产管理、对外投资、货币资金等管理数据的总称','数据资源','T/CIATCM 001-2019',1),
(37,'中医医院物资与设备管理数据','指医院物资和设备管理数据的总称，包括低值易耗品、医疗和行政办公物资、被服衣物等非固定资产物品的数据及各类固定资产的数据','数据资源','T/CIATCM 001-2019',1),
(38,'中医医院信息化建设数据','指中医医院信息化建设项目实施过程中的所有数据的总称，包括基础准备、软件实施和硬件实施、验证考核、推广应用等数据','数据资源','T/CIATCM 001-2019',1),
(39,'中医药科研项目管理数据','指中医药管理部门下达的科研课题，或中医药企事业单位承担的中医药类科研课题，对课题从项目申请、立项论证、组织实施、检查评估、验收鉴定、成果申报、科技推广、档案入卷等全程管理的数据总称','数据资源','T/CIATCM 001-2019',1),
(40,'中医医疗质量监控数据','指对中医医疗质量监控管理全过程的数据总称，包括临床诊疗、质量监测、评价与调控等数据','数据资源','T/CIATCM 001-2019',1),
(41,'中医药术语集','指中医药学科领域内的术语集合，包括中医基础理论、中医临床和社会环境等影响疾病发生发展的各类因素的名词术语','数据资源','T/CIATCM 001-2019',1),
(42,'居民健康卡','指中华人民共和国居民拥有的，在医疗卫生服务活动中用于身份识别，满足健康信息存储，实现跨地区和跨机构就医、数据交换和费用结算的基础载体','数据资源','T/CIATCM 001-2019',1),
(43,'电子健康档案','指电子化的居民健康档案，是关于医疗保健对象健康状况的信息数据资源库','数据资源','T/CIATCM 001-2019',1),
(44,'电子病历','指由医疗机构以电子化方式创建、保存、使用的重点针对门诊、住院患者（或保健对象）临床诊疗和指导干预信息的数据集成系统，是居民个人在医疗机构历次就诊过程中产生和被记录的完整、详细的临床信息资源','数据资源','T/CIATCM 001-2019',1),
(45,'结构化电子病历','指从医学信息学的角度将以自然语言方式录入的医疗文书，按照医学术语的要求进行结构化分析，并将这些语义结构最终以关系型（面向对象）结构的方式保存到数据库中','数据资源','T/CIATCM 001-2019',1),
(46,'中医电子病历','指按照国家中医药管理局《中医病历书写基本规范》执行，使用国家中医药管理局统一制定的项目名称、格式和内容，包括门（急）诊电子病历、住院电子病历及其他电子医疗记录','数据资源','T/CIATCM 001-2019',1),
(47,'中医临床诊疗数据','指病人在医院就诊所产生数据的总称，包括中医电子病历的全部内容及预后等数据','数据资源','T/CIATCM 001-2019',1),
(48,'中医临床科研数据','指用于中医临床科学研究的数据的总称，包括临床诊疗全过程的原始资料及为特定研究目的而收集的其他相关数据','数据资源','T/CIATCM 001-2019',1),
(49,'临床中药基本信息','指临床中药学领域，用于中药临床研究和规范化管理的信息项的总称，包括中药药用属性、炮制加工、临床应用、用药安全和信息管理等基本信息','数据资源','T/CIATCM 001-2019',1),
(50,'中医临床数据仓库','指基于实际的临床诊疗，实现对中医诊疗数据进行多主题、多粒度、多需求、高效、快捷的展示、研究和查询检索，并支持基于 Web 的 OLAP 共性应用，为中医临床评价研究和临床科研提供实际的诊疗数据证据和知识来源，以支持临床科研决策分析，满足中医临床研究需求的数据仓库','数据资源','T/CIATCM 001-2019',1),
(51,'公文','指公务文书，是机关、组织在公务活动中，按照特定的体例格式、经过一定的处理程序形成和使用的资料','应用系统','T/CIATCM 001-2019',1),
(52,'公文管理','指包括公文的拟稿、发文、登记、拟办、批办、承办、催办、流转、整理（立卷）、归档等一系列相互关联、衔接有序的管理工作','应用系统','T/CIATCM 001-2019',1),
(53,'办公自动化','指一种用于集成办公活动的信息处理系统（[JGJ/T 313-2013，定义 6.1.7]）','应用系统','T/CIATCM 001-2019',1),
(54,'健康信息云平台','指区域卫生信息化的核心与基础，区域内实现信息共享与交换、流程整合与协作、资源管理与配置、业务监督与考核等管理支撑平台，构建统一规范的电子健康档案资源库、电子病历资源库和人口信息资源库动态协同平台，公共卫生、计划生育、医疗服务、医疗保障、药品供应和综合管理运行服务平台','应用系统','T/CIATCM 001-2019',1),
(55,'云计算平台','指云服务商提供的云基础设施及其上的服务软件的集合（[GB/T 31168-2014，定义 3.6]）','应用系统','T/CIATCM 001-2019',1),
(56,'区域卫生信息平台','指连接区域内的医疗卫生机构基本业务信息系统的数据交换和共享平台，是不同系统间进行信息整合的基础和载体','应用系统','T/CIATCM 001-2019',1),
(57,'中医药项目预算管理信息服务平台','指针对中医药部门公共卫生服务补助资金项目，对项目预算管理过程中所产生的业务数据进行管理与分析利用的信息服务平台','应用系统','T/CIATCM 001-2019',1),
(58,'中医药电子政务系统','是指中医药政务部门应用信息技术履行行政和管理职能的信息系统（注：改写 GB/T 30850.1-2014，定义 3.3）','应用系统','T/CIATCM 001-2019',1),
(59,'中药资源普查信息管理系统','指根据中药资源普查规划要求，设计中药资源调查量表及其数据库，实现对普查所采集的各种中药资源数据的规范化管理和知识化分析利用的信息系统','应用系统','T/CIATCM 001-2019',1),
(60,'中医药综合统计网络直报信息系统','指中医医疗机构通过卫生专用网络，直接报送国家统一规定的中医药综合统计数据的信息系统，具有统计年报、月报上传，以及人力资源、医用设备、患者中医院病案首页、中医重点专科（专病）、中医药教育和科学研究等相关数据的采集分类、录入建库、数据质控和统计分析等功能','应用系统','T/CIATCM 001-2019',1),
(61,'医院信息系统','指在医院中使用的各类计算机应用系统的总称，包括电子病历、PACS、LIS、人事、财务、物资、事务等信息管理系统，以及医院信息化基础设施运行管理系统等；而只包括门诊挂号、划价收费、住院结算等功能的信息系统，是狭义的医院信息系统','应用系统','T/CIATCM 001-2019',1),
(62,'医院管理信息系统','指辅助医院管理与决策的医院行政事务处理的管理信息系统','应用系统','T/CIATCM 001-2019',1),
(63,'中医药数据交互平台','指通过计算机网络构建的，为中医药各信息系统提供信息交换的平台，具有数据传输、交换、共享等功能','应用系统','T/CIATCM 001-2019',1),
(64,'中医医院资源管理信息系统','指依据中医医院资源管理规范和流程设计的医院资源管理信息系统，通过对医院资源要素的规范化和数据化管理，提供医院资源数据采集、存储、传输、查询和统计分析等医院运营管理和辅助决策功能','应用系统','T/CIATCM 001-2019',1),
(65,'中医医院成本核算管理信息系统','指依据中医医院管理理论和方法，以科室、医疗服务项目、病种、诊次、床日为核算对象的运营成本进行管理的信息系统，具有医院总成本和单位成本核算和相关数据管理与决策分析等功能','应用系统','T/CIATCM 001-2019',1),
(66,'中医医院护理管理信息系统','指依据中医医院护理管理规范和工作流程设计的管理信息系统，具有数据的采集、存储、传输、查询和统计分析等临床护理管理辅助决策功能','应用系统','T/CIATCM 001-2019',1),
(67,'名医经验传承信息系统','指协助名老中医临床经验总结和学术思想研究的信息系统','应用系统','T/CIATCM 001-2019',1),
(68,'中医治未病管理与服务信息系统','指为居民提供中医治未病的管理与服务的信息系统，包括专项健康监测和治未病服务等功能；专项健康监测以中医体质辨识、饮食偏颇、居住环境、中医习惯用药史为主；治未病服务是指根据中医体质辨识辅助用户得到更好的治未病专业服务','应用系统','T/CIATCM 001-2019',1),
(69,'中医临床护理信息系统','指利用计算机软硬件技术、网络通信技术等现代化手段，对中医医院临床护理患者识别、医嘱查询执行、护理交班报告、床位管理、中医护理文书、中医护理方案护理效果评价等进行综合管理，对中医护理活动各阶段产生的数据进行采集、储存、处理、分析、传输及交换，为中医医院临床护理工作的整体运行提供全面的、自动化的管理及各种服务的信息系统','应用系统','T/CIATCM 001-2019',1),
(70,'医院检验系统','指专为医院检验科设计的一套实验室信息管理系统，能将实验仪器与计算机组成网络，使病人样品登录、实验数据存取、报告审核、打印分发、实验数据统计分析等繁杂的操作过程实现智能化、自动化和规范化管理','应用系统','T/CIATCM 001-2019',1),
(71,'医学影像存储和传输系统','指把各种医学影像通过接口以数字化的方式采集、显示、存储、传送和管理的应用系统','应用系统','T/CIATCM 001-2019',1),
(72,'移动医疗','指通过使用移动通信技术（例如：移动终端设备、移动电话和卫星通信）来提供医疗服务和信息','应用系统','T/CIATCM 001-2019',1),
(73,'移动医生工作站','指基于医院现有的 HIS 基础信息平台，通过无线局域网络或者是有线同步工具，以及移动数字设备实现临床一线医护人员随时随地进行病人相关信息的浏览、查询、采集和传输','应用系统','T/CIATCM 001-2019',1),
(74,'移动护理工作站','指以 HIS 为支撑，以个人数字助手、移动护理推车和智能手机等为硬件，以无线局域网为网络平台，为护理人员在床旁工作提供方便的应用系统','应用系统','T/CIATCM 001-2019',1),
(75,'移动临床药师工作站','指支持药师深入临床科室进行药师查房或参与会诊，辅助药师制定药师查房计划，通过调阅病人第一手临床信息，实时分析病人用药安全性和合理性，进行治疗药物监测，设计个性化给药方案，提供药物咨询，完成临床药历和查房记录，提升临床用药准确率','应用系统','T/CIATCM 001-2019',1),
(76,'远程会诊','指医疗机构之间利用通讯技术、计算机及网络技术，采用离线或在线交互方式，开展异地指导检查、协助诊断、指导治疗等医疗活动','应用系统','T/CIATCM 001-2019',1),
(77,'远程监护','指通过通信网络和计算机系统，使用音、视频等媒体为危重患者提供不同医疗机构之间的协同和跨专业的治疗','应用系统','T/CIATCM 001-2019',1),
(78,'远程心电诊断','指由邀请方向受邀方提出申请并提供患者临床资料和心电图资料，由受邀方出具诊断意见及报告，包含动态心电监护资料的远程诊断','应用系统','T/CIATCM 001-2019',1),
(79,'远程医疗','指采用现代通讯、电子和多媒体计算机技术，依托区域性信息平台或多个医疗机构之间的信息网络，实现医疗信息的远程采集、传输、处理、存储和查询，对异地患者实施咨询、会诊、监护、查房、协助诊断、指导检查、治疗、手术、教学、信息服务及其他特殊医疗活动的信息系统，实现各个医疗机构之间一对一、一对多、多对一的远程医疗服务','应用系统','T/CIATCM 001-2019',1),
(80,'远程影像传输','指通过计算机网络对患者的影像资料进行远程传递，使不同地点的影像专家或医师可共享影像资料并进行解读或会诊','应用系统','T/CIATCM 001-2019',1),
(81,'中医辅助诊疗系统','指通过技术手段利用软件生成看病过程中的结构化数据，结合中医在诊疗过程中的整体观念和辨证论治，在对疾病的现状进行周密分析的基础上，结合人工智能模型，在整个诊疗过程中给医生提供辅助作用的应用系统，也称中医辨证论治信息系统；基于中医专家经验构建的中医辅助诊疗系统称为中医专家系统','应用系统','T/CIATCM 001-2019',1),
(82,'中药煎药管理与质量控制系统','指以计算机技术、网络通讯等技术，对中药的煎药过程进行信息化管理和质量控制的系统，主要包括中药煎药过程数据采集、处理、存储、传输及交换、分析与利用等基本功能，是实现中药调剂、传输、泡药、煎药、包装、配送等全过程进行信息化管理','应用系统','T/CIATCM 001-2019',1),
(83,'中医临床科研信息一体化平台','指以中医临床术语规范研究为基础，在技术上包括结构化临床信息采集、多源数据管理和临床数据仓库等，建立在海量的中医临床诊疗信息库，并形成面向中医临床研究的分析数据集和联机分析挖掘软件平台','应用系统','T/CIATCM 001-2019',1),
(84,'远程教育','指利用信息技术实现在空间（有时需要连接）和时间（异步教学）上分布的教学活动和环境','应用系统','T/CIATCM 001-2019',1),
(85,'中医远程教育信息系统','指借助网络通讯技术，授课专家通过实时音视频和课件等方式为基层中医医生提供业务培训、教学以及技术支持的信息系统（注：改写 WS/T 529-2016，定义 2.8）','应用系统','T/CIATCM 001-2019',1),
